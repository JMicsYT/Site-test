# Скопируйте: cp config/ssl-selfsigned.env.example config/ssl-selfsigned.env
# Используется scripts/ssl-selfsigned.sh и ssl-selfsigned-renew.sh

# IP сервера (обязательно для доступа по https://IP)
SSL_IP=2.26.123.200

# Доп. имена в SAN (через запятую в скрипте — одно DNS по умолчанию)
SSL_DNS=localhost

# Common Name в сертификате
SSL_CN=2.26.123.200

# Срок действия (дней). Для тестов 90 — чаще срабатывает авто-перевыпуск
SSL_DAYS=90

# Перевыпустить, если до истечения осталось меньше N дней
RENEW_BEFORE_DAYS=30
