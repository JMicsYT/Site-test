# Фрагмент для /srv/shoshop/.env при деплое по IP без SSL.
# Nginx: config/nginx/shoshop.http.conf → default.conf (см. docker-compose.yml)
# Открывайте сайт только так: http://ВАШ_IP/  (не https, не :8000)

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=2.26.123.200
DJANGO_SECURE_SSL_REDIRECT=false
SECURE_PROXY_SSL_HEADER=false
DJANGO_COOKIE_SECURE=false
CSRF_TRUSTED_ORIGINS=http://2.26.123.200

POSTGRES_HOST=db
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
