# Фрагмент для /srv/shoshop/.env при HTTPS с самоподписанным сертификатом.
# Запуск: docker compose -f docker-compose.yml -f docker-compose.selfsigned.yml up -d

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=2.26.123.200
DJANGO_SECURE_SSL_REDIRECT=true
SECURE_PROXY_SSL_HEADER=true
DJANGO_COOKIE_SECURE=true
CSRF_TRUSTED_ORIGINS=https://2.26.123.200

POSTGRES_HOST=db
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
