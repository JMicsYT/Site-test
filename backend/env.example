# Скопируйте этот файл в .env и заполните значения.
# Путь: backend/.env

# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
PROJECT_NAME=ShoShop

# PostgreSQL (Docker: POSTGRES_HOST=db, локально: POSTGRES_HOST=localhost)
POSTGRES_DB=shoshop
POSTGRES_USER=shoshop
POSTGRES_PASSWORD=shoshop
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Кеш (Redis). Если пусто — используется локальный кеш в памяти
CACHE_URL=

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Письма (сброс пароля, подтверждение email)
DEFAULT_FROM_EMAIL=no-reply@example.com
DEFAULT_DOMAIN=localhost
# Для реальной отправки писем (сброс пароля, подтверждение email) задайте:
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=...
# EMAIL_HOST_PASSWORD=...

# Требовать подтверждённый email для заказов (true/false). В разработке можно false
REQUIRE_EMAIL_VERIFIED_FOR_PURCHASE=true

# Ограничение попыток входа (по IP + имя пользователя)
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300

# Платежи
PAYMENT_PROVIDER_CLASS=apps.payments.providers.StubPaymentProvider
PAYMENT_API_KEY=
PAYMENT_API_SECRET=
PAYMENT_CALLBACK_URL=https://yourdomain.com/api/payments/callback/
PAYMENT_CALLBACK_SECRET=

# HTTPS (за обратным прокси с SSL)
DJANGO_SECURE_SSL_REDIRECT=false
# Включите, если сайт за nginx/haproxy, проксирующим HTTPS на HTTP:
SECURE_PROXY_SSL_HEADER=false

# =====================================================================
# БЕЗОПАСНОСТЬ (рекомендуется активно настраивать в продакшене)
# =====================================================================

# Проверка пароля через HIBP (Have I Been Pwned) при регистрации/смене
HIBP_CHECK_ENABLED=true

# Блокировка аккаунта после N неудач (в дополнение к IP rate-limit)
ACCOUNT_LOCKOUT_MAX_FAILURES=10
ACCOUNT_LOCKOUT_DURATION=1800

# Content Security Policy (браузерная защита от XSS)
CSP_ENABLED=true

# Шифрование чувствительных полей в БД (DigitalItem.value).
# Сгенерируйте командой: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ВНИМАНИЕ: ключ менять нельзя — зашифрованные данные станут недоступны.
FIELD_ENCRYPTION_KEY=

# Подпись одноразовых ссылок на скачивание цифрового товара
DOWNLOAD_LINK_SECRET=
DOWNLOAD_LINK_TTL=900
DOWNLOAD_LINK_MAX_USES=3

# Платёжный callback: окно валидности timestamp, защита от replay-атак
PAYMENT_CALLBACK_REPLAY_WINDOW=300
