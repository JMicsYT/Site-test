# Скопируйте этот файл в .env (в той же папке backend) и отредактируйте значения.
# Файл .env не должен попадать в git (добавьте его в .gitignore).

# Django
DJANGO_SECRET_KEY=dev-secret-key-123
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Docker: POSTGRES_HOST=db, локально: POSTGRES_HOST=localhost)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shoshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=QpAlZmoi516?56

# Письма и домен
DEFAULT_FROM_EMAIL=no-reply@shoshop.local
DEFAULT_DOMAIN=127.0.0.1:8000

# Опционально: Celery/Redis (если не задано, письма отправляются синхронно в консоль)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Платёжный провайдер (заглушка по умолчанию)
# PAYMENT_PROVIDER_CLASS=apps.payments.providers.StubPaymentProvider
# PAYMENT_API_KEY=
# PAYMENT_API_SECRET=
# PAYMENT_CALLBACK_URL=https://localhost/api/payments/callback/
 
FIELD_ENCRYPTION_KEY=<python -c "import secrets; print(secrets.token_urlsafe(64))">
DOWNLOAD_LINK_SECRET=<другая длинная случайная строка>
PAYMENT_CALLBACK_SECRET=<от платёжной системы>
HIBP_CHECK_ENABLED=true
ACCOUNT_LOCKOUT_MAX_FAILURES=10
CSP_ENABLED=true
DJANGO_SECURE_SSL_REDIRECT=false
SECURE_PROXY_SSL_HEADER=false

TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_BOT_TOKEN=<token>
TELEGRAM_ADMIN_CHAT_ID=<chat_id>